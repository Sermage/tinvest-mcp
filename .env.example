# T-Invest API token (from https://www.tbank.ru/invest/settings/api/)
TINVEST_TOKEN=

# true => use sandbox endpoint
TINVEST_SANDBOX=false

# true => order-placing tools are not registered
TINVEST_READONLY=true

# Identifies this app in T-Invest analytics
TINVEST_APP_NAME=tinvest-mcp

# Portfolio snapshot interval in minutes (default: 60)
TINVEST_SNAPSHOT_INTERVAL=60

# Path to SQLite database (default: ./data/snapshots.db)
# TINVEST_DB_PATH=/opt/tinvest-mcp/data/snapshots.db
